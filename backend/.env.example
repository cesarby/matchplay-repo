# Copia este fichero a .env y rellena tus valores locales.
# El fichero .env NO se commitea (está en .gitignore).

# Base de datos MySQL
DB_URL=jdbc:mysql://localhost:3306/matchplay?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USER=root
DB_PASS=tu_password_aqui

# JWT — genera una clave aleatoria de mínimo 64 caracteres
JWT_SECRET=cambia_esto_por_una_clave_secreta_de_minimo_64_caracteres_muy_segura_aqui
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# Refresh cookie (false en dev http, true en prod https)
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_MAX_AGE_SECONDS=604800

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Spring
SPRING_PROFILE=dev

# BoardGameGeek API
BGG_API_BASE_URL=https://boardgamegeek.com/xmlapi2
BGG_API_USER_AGENT=matchplay-backend/1.0 (contact: tu_email@dominio.com)
BGG_API_TOKEN=tu_token_de_bgg
BGG_CONNECT_TIMEOUT_MS=5000
BGG_READ_TIMEOUT_MS=15000
